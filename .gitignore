# Cargo / Rust
debug/
target/
**/*.rs.bk
*.pdb

# Generated by cargo mutants
**/mutants.out*/

# Anchor build outputs live under target/ (already ignored above) — both
# .so files (target/deploy/*.so) and IDLs (target/idl/*.json). They're
# republished as part of the GitHub release bundle, never committed.

# Anchor CLI workspace cache (per-workspace logs, IDL caches, validator
# scratch space — regenerated by every `anchor build`/`anchor test`/`anchor deploy`).
.anchor/

# `solana-test-validator` ledger dump (anchor test spins one up in cwd by
# default; Surfpool is preferred for this repo but ad-hoc runs still land here).
test-ledger/

# Coverage outputs (cargo-llvm-cov / grcov / similar — regenerated locally
# and in CI; not committed).
*.profraw
lcov.info
/coverage/

# JetBrains
# .idea/

# Localnet outputs
/localnet/out/

# Release bundles (built by scripts/package-release.sh; published as
# GitHub release assets, not committed).
/release/

# Cargo-fuzz artifacts (fuzz/corpus/* IS committed under
# programs/ario-ant-escrow/fuzz/corpus/ — only the run-time outputs
# below are ignored).
**/fuzz/artifacts/
**/fuzz/coverage/

# OS / editor noise
.DS_Store
*.swp
*.swo

# CU baseline output (regenerated each capture; only committed when
# intentionally updating the per-event-PR snapshot).
/cu-baseline.json

# Devnet auto-generated developer keypairs — devnet program keypairs
# under target/deploy/ are gitignored already; the explicit pattern
# below covers the cases where someone keeps them outside target/.
*-keypair.json
!program-ids/*.json

# Node tools (idl-event-snapshot.mjs runs without yarn; if a contributor
# adds a yarn project later, both these directories stay ignored).
node_modules/

# TypeScript / Yarn artifacts — Anchor.toml's `[scripts] test` line implies
# a future ts-mocha test scaffold under tests/. These rules pre-empt the
# usual generated detritus once that lands. Lockfiles (yarn.lock /
# package-lock.json) are intentionally NOT ignored: when a TS scaffold
# appears the lockfile should be committed for reproducible installs.
dist/
*.tsbuildinfo
.yarn/cache/
.yarn/install-state.gz
.yarn/build-state.yml
.yarn/unplugged/
.pnp.*
.cursor/